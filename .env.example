# ============================================
# EVOLUTION API
# ============================================
SERVER_URL=https://api.seudominio.com
AUTHENTICATION_API_KEY=sua-chave-forte-aqui-min-32-caracteres
DATABASE_CONNECTION_CLIENT_NAME=evolution_prod
LANGUAGE=pt_BR

# ============================================
# POSTGRES (exclusivo do Evolution — rede interna)
# ============================================
POSTGRES_USER=evolution
POSTGRES_PASSWORD=senha-forte-postgres
POSTGRES_DB=evolution

# Obrigatório — use a mesma senha de POSTGRES_PASSWORD
DATABASE_CONNECTION_URI=postgresql://evolution:senha-forte-postgres@postgres:5432/evolution?schema=public

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_USER=evolution
RABBITMQ_PASSWORD=senha-forte-rabbitmq
RABBITMQ_VHOST=evolution
RABBITMQ_EXCHANGE_NAME=evolution

# Obrigatório — use a mesma senha de RABBITMQ_PASSWORD
RABBITMQ_URI=amqp://evolution:senha-forte-rabbitmq@rabbitmq:5672/evolution

# Usuário somente leitura para o CRM (leadpronto.ai)
RABBITMQ_CRM_PASSWORD=senha-forte-crm

# Rede Docker compartilhada com leadpronto.ai no Coolify
# Criar no servidor antes do deploy: docker network create leadpronto_shared
COOLIFY_SHARED_NETWORK=leadpronto_shared

# Alternativa à rede compartilhada: expor AMQP no host (descomente ports no compose)
# RABBITMQ_PUBLISH_PORT=5672

# ============================================
# GRAFANA
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000
